Dialogue = "Something's strange about this place... The walls tell a story of an Ancient Sandwich Civilization... many burgers, hot dogs, and burritos once called this planet home."

[node name="Room3Dialogue3" parent="." unique_id=1868775560 instance=ExtResource("10_b83bg")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 27.41658, 2.499609, -37.677586)
Dialogue = "Unlike these mutant burgers, it seems the Burgerians were once a powerful and intelligent civilization. But it seems everything changed when the Great Sauce disappeared."

[node name="Room3Dialogue4" parent="." unique_id=1531642159 instance=ExtResource("10_b83bg")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -17.421452, 2.4996092, -37.816658)
Dialogue = "Something's weird... This section looks.. different? Almost like a lab was forcefully grafted into the ancient temple. It seems the mutants are coming from inside."

